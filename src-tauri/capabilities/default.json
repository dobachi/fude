{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "cli:default",
    "cli:allow-cli-matches",
    "updater:default",
    "process:default",
    "process:allow-exit",
    "core:window:allow-destroy",
    "core:window:allow-close"
  ]
}
