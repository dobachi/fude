{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Fude",
  "version": "0.2.6",
  "identifier": "com.dobachi.fude",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run build:frontend",
    "beforeBuildCommand": "npm run build:frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Fude",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "browserExtensionsEnabled": false,
        "devtools": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../dist/index.html": "browser/index.html",
      "../dist/style.css": "browser/style.css",
      "../dist/bundle.js": "browser/bundle.js",
      "../scripts/serve.js": "browser/serve.js",
      "../scripts/fude-browser": "browser/fude-browser",
      "../scripts/fude-remote": "browser/fude-remote"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "postInstallScript": "scripts/postinst.sh",
        "preRemoveScript": "scripts/prerm.sh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/dobachi/fude/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM2N0UzRDVBMDkzOENDNjIKUldSaXpEZ0pXajErTm9KelJrR2w0cFYyQWNDRW91MS91YksvMFdjNGFtRDV6ZjRwM1p5Yk10ZkIK"
    },
    "cli": {
      "args": [
        {
          "name": "path",
          "index": 1,
          "takesValue": true,
          "required": false,
          "description": "Path to a file or directory to open"
        },
        {
          "name": "remote",
          "short": "r",
          "takesValue": true,
          "required": false,
          "description": "Connect to a remote Fude server URL (e.g., http://localhost:3000)"
        }
      ]
    }
  }
}
