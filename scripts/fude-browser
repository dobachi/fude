#!/bin/sh
# fude-browser - Launch Fude in browser mode

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"

# Prefer local development files over installed version
if [ -f "$SCRIPT_DIR/serve.js" ] && [ -d "$SCRIPT_DIR/../dist" ]; then
  RES="$SCRIPT_DIR/../dist"
  SERVE="$SCRIPT_DIR/serve.js"
elif [ -d "/usr/lib/Fude/browser" ]; then
  RES="/usr/lib/Fude/browser"
  SERVE="/usr/lib/Fude/browser/serve.js"
elif [ -d "/usr/lib/fude/browser" ]; then
  RES="/usr/lib/fude/browser"
  SERVE="/usr/lib/fude/browser/serve.js"
else
  echo "Error: Fude resources not found"
  exit 1
fi

if [ ! -f "$SERVE" ]; then
  echo "Error: serve.js not found"
  exit 1
fi

export FUDE_DIST_DIR="$RES"
exec node "$SERVE" "$@"
