#!/bin/sh
# fude-browser - Launch Fude in browser mode

# Find resource directory
if [ -d "/usr/lib/Fude/browser" ]; then
  RES="/usr/lib/Fude/browser"
elif [ -d "/usr/lib/fude/browser" ]; then
  RES="/usr/lib/fude/browser"
else
  # Development mode
  SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
  RES="$SCRIPT_DIR/../dist"
  SERVE="$SCRIPT_DIR/serve.js"
fi

SERVE="${SERVE:-$RES/serve.js}"

if [ ! -f "$SERVE" ]; then
  echo "Error: serve.js not found"
  exit 1
fi

export FUDE_DIST_DIR="$RES"
exec node "$SERVE" "$@"
