{
  "name": "markdown-editor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:frontend": "esbuild src/js/app.js --bundle --outfile=dist/bundle.js --format=esm --sourcemap --watch",
    "build:frontend": "cp src/index.html src/style.css dist/ && esbuild src/js/app.js --bundle --outfile=dist/bundle.js --format=esm --minify --tree-shaking=true",
    "tauri": "tauri",
    "dev": "tauri dev",
    "build": "tauri build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/js/",
    "lint:fix": "eslint src/js/ --fix",
    "lint:rust": "cd src-tauri && cargo clippy -- -D warnings",
    "format": "prettier --write 'src/**/*.{js,css,html}'",
    "format:check": "prettier --check 'src/**/*.{js,css,html}'",
    "format:rust": "cd src-tauri && cargo fmt",
    "check": "npm run format:check && npm run lint && npm run test && npm run build:frontend"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@replit/codemirror-vim": "^6.3.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-cli": "^2.4.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "codemirror": "^6.0.2",
    "markdown-it": "^14.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.10.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "vitest": "^4.1.0"
  }
}
